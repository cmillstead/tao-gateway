# Database
POSTGRES_USER=tao
POSTGRES_PASSWORD=<set-a-strong-password>
POSTGRES_DB=tao_gateway
DATABASE_URL=postgresql+asyncpg://tao:<your-password>@localhost:5432/tao_gateway

# Redis
REDIS_URL=redis://localhost:6379/0

# App
APP_NAME=TaoGateway
APP_VERSION=0.1.0
DEBUG=false

# Auth — generate with: openssl rand -hex 32
JWT_SECRET_KEY=<generate-with-openssl-rand-hex-32>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Bittensor
WALLET_NAME=default
WALLET_PATH=~/.bittensor/wallets
HOTKEY_NAME=default
SUBTENSOR_NETWORK=finney
SN1_NETUID=1
METAGRAPH_SYNC_INTERVAL_SECONDS=120
DENDRITE_TIMEOUT_SECONDS=30
